</div>
<style>
  #slideMobile {
    display: none;
  }
  #slideCom {
    display: contents;
    
  }
  .content {
    width: 1440px;
    max-width: 100%;
  }
    img {
        padding: 3px;
        width: auto;
        height: auto;
        border-radius: 10px;
    }
    @media screen and (max-width: 600px) {
      #slideCom {
        display: none;
      }
      #slideMobile {
        display: contents;
      }
    }
</style>


<script>
  import { AutoScroll } from '@splidejs/splide-extension-auto-scroll';
  import { initSplideExtension } from "astro-splide/js/splideExtensionUtils"
  initSplideExtension({AutoScroll})
</script>