---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
// Cấu hình Splide  -  yêu cầu npm install astro-splide @splidejs/splide-extension-auto-scroll

import "@splidejs/splide/css"
import { SplideExtension, SplideSlide } from 'astro-splide';
import type { Options } from '@splidejs/splide';

const option: Options = {
    type: 'loop',
    drag: 'free',
    focus: 'center',
    perPage: 1,
    autoScroll: {
        speed: 0,
    },
}

interface Props {
   imagePath: string;
   altText: string;
   name: string;
   age: number;
}

const { imagePath, altText, name, age} = Astro.props;
const images = import.meta.glob.('/src/assets/*.{jpeg,jpg,png,gif}', { eager: true })

---

<div id="slideCom" class="content">
    <SplideExtension options={option}>
        {images.map((image) => 
            <SplideSlide>
                <Image src={image} />
            </SplideSlide>
        )
    </SplideExtension>
</div>